<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.premierservices.Controllers.EditarPortafolioController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Editar Portafolio" />

                <!-- Campo ID del proveedor (se ocultará en modo proveedor) -->
                <VBox fx:id="proveedorIdBox" spacing="5.0">
                    <Label text="ID del Proveedor" />
                    <TextField fx:id="txtIdProveedor" editable="false" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Nombre del Servicio" />
                    <TextField fx:id="txtNombreServicio" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Categoría" />
                    <ComboBox fx:id="cmbCategoria" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Ubicación" />
                    <ComboBox fx:id="cmbUbicacion" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Precio (RD$)" />
                    <TextField fx:id="txtPrecio" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Descripción" />
                    <TextArea fx:id="txtDescripcion" prefHeight="80" wrapText="true" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="Imagen (ruta)" />
                    <HBox spacing="10.0">
                        <TextField fx:id="txtRutaImagen" HBox.hgrow="ALWAYS" />
                        <Button onAction="#seleccionarImagen" text="Examinar..." />
                    </HBox>
                </VBox>

                <Label fx:id="lblMensaje" wrapText="true" />

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <Button onAction="#guardar" style="-fx-background-color: #003566; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar" />
                    <Button onAction="#cancelar" style="-fx-background-color: #778899; -fx-text-fill: white;" text="Cancelar" />
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>