<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.premierservices.Controllers.GlobalController.SeleccionPlanController"
            prefWidth="1100" prefHeight="720"
            style="-fx-background-color:#f0f4f8;">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color:#0A1832; -fx-padding:12 28 12 28;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Premier Services"
                           style="-fx-font-size:19px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="6" alignment="CENTER">
                    <Button text="Inicio" style="-fx-background-color:transparent; -fx-text-fill:#a0aec0; -fx-cursor:hand; -fx-font-size:13px; -fx-padding:6 12;"/>
                    <Button text="Reservas" style="-fx-background-color:transparent; -fx-text-fill:#a0aec0; -fx-cursor:hand; -fx-font-size:13px; -fx-padding:6 12;"/>
                    <Button text="Sign In" style="-fx-background-color:transparent; -fx-text-fill:#a0aec0; -fx-cursor:hand; -fx-font-size:13px; -fx-padding:6 12;"/>
                    <Button text="Register" style="-fx-background-color:#4A7FA9; -fx-text-fill:white; -fx-background-radius:7; -fx-cursor:hand; -fx-font-size:13px; -fx-padding:6 14;"/>
                </HBox>
                <StackPane prefWidth="34" prefHeight="34" style="-fx-background-color:#1e3a5f; -fx-background-radius:17;">
                    <Label text="User" style="-fx-font-size:12px; -fx-text-fill:white;"/>
                </StackPane>
            </HBox>
            <HBox style="-fx-background-color:#0d2244; -fx-padding:8 28;">
                <Button fx:id="btnAtras" text=" Atras" onAction="#irARegistro"
                        style="-fx-background-color:transparent; -fx-text-fill:#4A7FA9; -fx-cursor:hand; -fx-font-size:12px; -fx-padding:4 10; -fx-border-color:#4A7FA9; -fx-border-radius:6;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color:transparent; -fx-background:#f0f4f8;">
            <VBox spacing="0" style="-fx-background-color:transparent;">
                <VBox alignment="CENTER" spacing="8" style="-fx-padding:48 24 32 24;">
                    <Label text="Suscripciones" style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#0A1832;"/>
                    <Label text="Elige el plan que mejor se te acomode" style="-fx-font-size:15px; -fx-text-fill:#64748b;"/>
                </VBox>
                <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            minHeight="460" style="-fx-background-color:transparent; -fx-background:#f0f4f8; -fx-padding:0 24 24 24;">
                    <HBox spacing="24" alignment="CENTER" style="-fx-padding:4 40 12 40;">

                        <!-- Tarjeta Rookie -->
                        <VBox onMouseClicked="#onRookieClicked"
                              style="-fx-background-color:white; -fx-background-radius:18; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.09),14,0,0,4); -fx-cursor:hand; -fx-min-width:290; -fx-max-width:320;">
                            <padding><Insets top="32" right="28" bottom="28" left="28"/></padding>
                            <StackPane alignment="TOP_RIGHT">
                                <Label text="Starter" style="-fx-background-color:#e0f2fe; -fx-text-fill:#0369a1; -fx-background-radius:20; -fx-padding:3 12; -fx-font-size:11px; -fx-font-weight:bold;"/>
                            </StackPane>
                            <Label text=" Rookie" style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#0A1832;"/>
                            <HBox alignment="BASELINE_LEFT" spacing="2" style="-fx-padding:8 0 4 0;">
                                <Label text="Gratis" style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#0A1832;"/>
                            </HBox>
                            <Label text="Para empezar sin compromisos" style="-fx-font-size:11px; -fx-text-fill:#94a3b8; -fx-padding:0 0 16 0;"/>
                            <Separator style="-fx-background-color:#e2e8f0;"/>
                            <VBox spacing="10" style="-fx-padding:16 0 20 0;">
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="1 servicio publicado" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Perfil basico visible" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Hasta 5 solicitudes/mes" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Soporte por email" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✘" style="-fx-text-fill:#d1d5db;"/><Label text="Sin estadisticas" style="-fx-font-size:13px; -fx-text-fill:#d1d5db;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✘" style="-fx-text-fill:#d1d5db;"/><Label text="Sin posicionamiento" style="-fx-font-size:13px; -fx-text-fill:#d1d5db;"/></HBox>
                            </VBox>
                            <Button fx:id="btnRookie" text="Elegir plan" onAction="#seleccionarRookie"
                                    style="-fx-background-color:#f1f5f9; -fx-text-fill:#0A1832; -fx-background-radius:10; -fx-cursor:hand; -fx-font-weight:bold; -fx-font-size:13px; -fx-padding:10 0;" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Tarjeta Elite -->
                        <VBox onMouseClicked="#onEliteClicked"
                              style="-fx-background-color:#0A1832; -fx-background-radius:18; -fx-effect:dropshadow(gaussian,rgba(10,24,50,0.35),22,0,0,8); -fx-cursor:hand; -fx-min-width:310; -fx-max-width:340; -fx-translate-y:-12;">
                            <padding><Insets top="32" right="28" bottom="28" left="28"/></padding>
                            <StackPane alignment="TOP_RIGHT">
                                <Label text="Popular" style="-fx-background-color:#4A7FA9; -fx-text-fill:white; -fx-background-radius:20; -fx-padding:3 12; -fx-font-size:11px; -fx-font-weight:bold;"/>
                            </StackPane>
                            <Label text=" Elite" style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                            <HBox alignment="BASELINE_LEFT" spacing="4" style="-fx-padding:8 0 4 0;">
                                <Label text="USD 29" style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                                <Label text="/mes" style="-fx-font-size:13px; -fx-text-fill:#94a3b8; -fx-translate-y:4;"/>
                            </HBox>
                            <Label text="El favorito de los profesionales" style="-fx-font-size:11px; -fx-text-fill:#94a3b8; -fx-padding:0 0 16 0;"/>
                            <Separator style="-fx-background-color:#1e3a5f;"/>
                            <VBox spacing="10" style="-fx-padding:16 0 20 0;">
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Hasta 10 servicios publicados" style="-fx-font-size:13px; -fx-text-fill:#e2e8f0;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Perfil destacado con foto" style="-fx-font-size:13px; -fx-text-fill:#e2e8f0;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Solicitudes ilimitadas" style="-fx-font-size:13px; -fx-text-fill:#e2e8f0;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Estadisticas basicas" style="-fx-font-size:13px; -fx-text-fill:#e2e8f0;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Soporte prioritario" style="-fx-font-size:13px; -fx-text-fill:#e2e8f0;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✘" style="-fx-text-fill:#334155;"/><Label text="Sin posicionamiento premium" style="-fx-font-size:13px; -fx-text-fill:#475569;"/></HBox>
                            </VBox>
                            <Button fx:id="btnElite" text="Elegir plan" onAction="#seleccionarElite"
                                    style="-fx-background-color:#4A7FA9; -fx-text-fill:white; -fx-background-radius:10; -fx-cursor:hand; -fx-font-weight:bold; -fx-font-size:13px; -fx-padding:10 0;" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Tarjeta Prime -->
                        <VBox onMouseClicked="#onPrimeClicked"
                              style="-fx-background-color:white; -fx-background-radius:18; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.09),14,0,0,4); -fx-cursor:hand; -fx-min-width:290; -fx-max-width:320;">
                            <padding><Insets top="32" right="28" bottom="28" left="28"/></padding>
                            <StackPane alignment="TOP_RIGHT">
                                <Label text="Premium" style="-fx-background-color:#fef9c3; -fx-text-fill:#854d0e; -fx-background-radius:20; -fx-padding:3 12; -fx-font-size:11px; -fx-font-weight:bold;"/>
                            </StackPane>
                            <Label text=" Prime" style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#0A1832;"/>
                            <HBox alignment="BASELINE_LEFT" spacing="4" style="-fx-padding:8 0 4 0;">
                                <Label text="USD 79" style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#0A1832;"/>
                                <Label text="/mes" style="-fx-font-size:13px; -fx-text-fill:#94a3b8; -fx-translate-y:4;"/>
                            </HBox>
                            <Label text="Para quienes van en serio" style="-fx-font-size:11px; -fx-text-fill:#94a3b8; -fx-padding:0 0 16 0;"/>
                            <Separator style="-fx-background-color:#e2e8f0;"/>
                            <VBox spacing="10" style="-fx-padding:16 0 20 0;">
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Servicios ilimitados" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Perfil con video y portafolio" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Solicitudes ilimitadas" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Estadisticas avanzadas" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Posicionamiento 1" style="-fx-font-size:13px;"/></HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT"><Label text="✔" style="-fx-text-fill:#22c55e;"/><Label text="Soporte 24/7 dedicado" style="-fx-font-size:13px;"/></HBox>
                            </VBox>
                            <Button fx:id="btnPrime" text="Elegir plan" onAction="#seleccionarPrime"
                                    style="-fx-background-color:#f1f5f9; -fx-text-fill:#0A1832; -fx-background-radius:10; -fx-cursor:hand; -fx-font-weight:bold; -fx-font-size:13px; -fx-padding:10 0;" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>
                </ScrollPane>
                <VBox alignment="CENTER" spacing="10" style="-fx-padding:12 0 40 0;">
                    <Label fx:id="labelSeleccionado" text="Ningun plan seleccionado" style="-fx-font-size:13px; -fx-text-fill:#94a3b8;"/>
                    <Button fx:id="btnSiguiente" text="Continuar" onAction="#guardarSeleccion"
                            style="-fx-background-color:#cbd5e1; -fx-text-fill:#94a3b8; -fx-font-weight:bold; -fx-font-size:15px; -fx-background-radius:12; -fx-padding:13 60 13 60;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="8" style="-fx-background-color:#0A1832; -fx-padding:10 24;">
            <Label text="2025 Premier Services - Todos los derechos reservados" style="-fx-text-fill:#4A7FA9; -fx-font-size:11px;"/>
        </HBox>
    </bottom>
</BorderPane>