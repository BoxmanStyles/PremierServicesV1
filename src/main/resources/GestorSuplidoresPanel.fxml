                                <Text fill="#7f8c8d" strokeType="OUTSIDE" strokeWidth="0.0" text="— Cambiar plan y estado de suplidores">
                                    <font><Font size="14.0" /></font>
                                </Text>
                            </children>
                        </HBox>
                        <Separator />

                        <!-- Panel de acción rápida -->
                        <GridPane hgap="20.0" prefHeight="160.0" prefWidth="1212.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="35.0" />
                                <ColumnConstraints percentWidth="30.0" />
                                <ColumnConstraints percentWidth="35.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                            <children>

                                <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
