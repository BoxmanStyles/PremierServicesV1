                                    </children>
                                </VBox>

                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label style="-fx-text-fill: #34495e; -fx-font-weight: bold;" text="Cambiar Plan de Suscripción">
                                            <font><Font size="12.0" /></font>
                                        </Label>
                                        <ComboBox fx:id="cmbPlan" prefWidth="300.0" promptText="Seleccionar plan" style="-fx-font-size: 13;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <children>
                                        <Label style="-fx-text-fill: #34495e; -fx-font-weight: bold;" text="Estado de Cuenta">
                                            <font><Font size="12.0" /></font>
                                        </Label>
                                        <ComboBox fx:id="cmbEstado" prefWidth="300.0" promptText="Seleccionar estado" style="-fx-font-size: 13;" />
                                    </children>
                                </VBox>

                                <HBox prefHeight="38.0" prefWidth="1166.0" spacing="15.0" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="1">
                                    <children>
                                        <Button onAction="#onGuardarCambios" prefHeight="38.0" prefWidth="180.0" style="-fx-background-color: #007cff; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Guardar Cambios" />
                                        <Button onAction="#onLimpiarSeleccion" prefHeight="38.0" prefWidth="130.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Limpiar" />
                              <Region prefHeight="38.0" prefWidth="412.0" />
                                    <TextField fx:id="txtBusqueda" prefHeight="33.0" prefWidth="299.0" promptText="Buscar proveedor..." style="-fx-background-radius: 15; -fx-padding: 8;" />
                                    </children>
                                </HBox>

                            </children>
                        </GridPane>

                        <!-- Tabla de suplidores -->
                        <TableView fx:id="tablaSuplidores" prefHeight="420.0" prefWidth="1180.0">
                            <columns>
                                <TableColumn fx:id="colIdSuplidor" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="colNombreEmpresa" prefWidth="210.0" text="Empresa" />
                                <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                                <TableColumn fx:id="colTelefono" prefWidth="165.0" text="Teléfono" />
                                <TableColumn fx:id="colUbicacion" prefWidth="184.0" text="Ubicación" />
                                <TableColumn fx:id="colPlan" prefWidth="114.0" text="Plan" />
                                <TableColumn fx:id="colCalificacion" prefWidth="119.0" text="Calificación" />
                                <TableColumn fx:id="colEstado" prefWidth="152.0" text="Estado" />
                            </columns>
                        </TableView>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

    </children>
</AnchorPane>
