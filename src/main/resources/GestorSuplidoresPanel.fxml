<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.premierservices.Controllers.GestorSuplidores.GestorSuplidoresPanelController">
    <children>

        <!-- Cabecera fija -->
        <VBox style="-fx-background-color: linear-gradient(to right, #0A1832, #4A7FA9);">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="105.0" prefWidth="1270.0" spacing="20.0" style="-fx-padding: 20;">
                    <children>
                        <Region prefHeight="65.0" prefWidth="394.0" />
                        <Region prefHeight="65.0" prefWidth="60.0" />
                        <Pane prefHeight="60.0" prefWidth="256.0">
                            <children>
                                <Text fill="#50b9ff" layoutX="31.0" layoutY="61.0" stroke="#0d0c0c" strokeType="OUTSIDE" strokeWidth="0.0" text="remier Services">
                                    <font><Font name="Elephant Italic" size="31.0" /></font>
                                    <effect><Glow level="0.37" /></effect>
                                </Text>
                                <ImageView fx:id="Logoimg" fitHeight="71.0" fitWidth="70.0" layoutX="-6.0" layoutY="4.0" pickOnBounds="true" preserveRatio="true">
                                    <Image url="@../../../IMG/Logo.png" />
                                    <effect><Glow level="0.81" /></effect>
                                </ImageView>
                            </children>
                        </Pane>
                        <Region prefHeight="65.0" prefWidth="283.0" />
                        <Pane prefHeight="65.0" prefWidth="195.0" style="-fx-background-color: #142440; -fx-background-radius: 24;">
                            <children>
                                <ImageView fx:id="imagenPerfil" fitHeight="50.0" fitWidth="45.0" layoutX="150.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />
                                <Button alignment="TOP_LEFT" layoutX="6.0" layoutY="12.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="170.0" style="-fx-background-color: transparent;" text="Gestor de Suplidores" textFill="WHITE">
                                    <font><Font size="13.0" /></font>
                                </Button>
                                <Button layoutX="6.0" layoutY="38.0" onAction="#cerrarSesion" style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b; -fx-font-size: 10px; -fx-cursor: hand;" text="Cerrar sesión" />
                            </children>
                        </Pane>
                    </children>
                </HBox>

                <!-- Barra de filtros por plan/estado -->
                <HBox alignment="CENTER_LEFT" prefHeight="53.0" prefWidth="1288.0" spacing="20.0" style="-fx-padding: 20;">
                    <children>
                        <Region prefHeight="25.0" prefWidth="75.0" />
                        <Button onAction="#filtrarTodos" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 10; -fx-border-width: 1;" text="📋 Todos" textFill="WHITE" />
                        <Button onAction="#filtrarRookie" style="-fx-background-color: transparent;" text="🟢 Rookie" textFill="WHITE" />
                        <Button onAction="#filtrarElite" style="-fx-background-color: transparent;" text="🔵 Elite" textFill="WHITE" />
                        <Button onAction="#filtrarPrime" style="-fx-background-color: transparent;" text="👑 Prime" textFill="WHITE" />
                        <Button onAction="#filtrarSuspendidos" style="-fx-background-color: transparent;" text="🔴 Suspendidos" textFill="WHITE" />
                        <Region prefHeight="25.0" prefWidth="72.0" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Contenido principal -->
        <ScrollPane fitToWidth="true" layoutY="158.0" prefHeight="659.0" prefWidth="1288.0" style="-fx-background-color: #f5f5f5;">
            <content>
                <VBox alignment="TOP_CENTER" prefHeight="935.0" prefWidth="1288.0" spacing="20.0" style="-fx-background-color: #f5f5f5;">
                    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="20.0" /></padding>
