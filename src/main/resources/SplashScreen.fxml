<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: linear-gradient(to bottom, #0A1832, #4A7FA9);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.premierservices.Controllers.SplashScreenController">
    <center>
        <VBox alignment="CENTER" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Premier Services">
                <font>
                    <Font name="Elephant Italic" size="36.0" />
                </font>
            </Label>
            <Label fx:id="lblEstado" style="-fx-text-fill: white; -fx-font-size: 14;" text="Cargando recursos..." />
            <ProgressIndicator fx:id="progressIndicator" progress="0.0" />
        </VBox>
    </center>
</BorderPane>
