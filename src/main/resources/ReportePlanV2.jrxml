<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="FacturaPlan" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="PremierServices_JasperSoft"/>

    <style name="TituloGrande" fontName="Arial" fontSize="28" isBold="true"/>
    <style name="TituloMediano" fontName="Arial" fontSize="16" isBold="true" isItalic="true"/>
    <style name="TituloPequeno" fontName="Arial" fontSize="11" isBold="true"/>
    <style name="TextoNormal" fontName="Arial" fontSize="9"/>
    <style name="TextoNegrita" fontName="Arial" fontSize="9" isBold="true"/>
    <style name="TextoPequeno" fontName="Arial" fontSize="8"/>
    <style name="TextoExtraPequeno" fontName="Arial" fontSize="7"/>
    <style name="HeaderTabla" fontName="Arial" fontSize="10" isBold="true"/>

    <parameter name="id_suplidor" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[1039]]></defaultValueExpression>
    </parameter>

    <queryString>
        <![CDATA[
		SELECT
			f.numero_factura,
			f.comprobante,
			CONVERT(VARCHAR, f.fecha, 103) AS fecha_factura,
			f.subtotal,
			ISNULL(f.itbis, 0) AS itbis,
			ISNULL(f.descuento, 0) AS descuento,
			f.total,
			f.estado,
			s.nombre_empresa,
			s.telefono,
			s.correo AS email,
			s.ubicacion,
			p.nombre_plan,
			p.precio AS precio_plan,
			p.beneficios,
			p.limite_fotos,
			p.prioridad_busqueda
		FROM dbo.tbl_factura f
		INNER JOIN dbo.tbl_suplidores s ON f.id_suplidor = s.id_suplidor
		INNER JOIN dbo.tbl_planes p ON s.plan_id = p.id_plan
		WHERE f.id_suplidor = $P{id_suplidor}
		ORDER BY f.numero_factura DESC
		]]>
    </queryString>

    <field name="numero_factura" class="java.lang.Integer"/>
    <field name="comprobante" class="java.lang.String"/>
    <field name="fecha_factura" class="java.lang.String"/>
    <field name="subtotal" class="java.math.BigDecimal"/>
    <field name="itbis" class="java.math.BigDecimal"/>
    <field name="descuento" class="java.math.BigDecimal"/>
    <field name="total" class="java.math.BigDecimal"/>
    <field name="estado" class="java.lang.String"/>
    <field name="nombre_empresa" class="java.lang.String"/>
    <field name="telefono" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="ubicacion" class="java.lang.String"/>
    <field name="nombre_plan" class="java.lang.String"/>
    <field name="precio_plan" class="java.math.BigDecimal"/>
    <field name="beneficios" class="java.lang.String"/>
    <field name="limite_fotos" class="java.lang.Integer"/>
    <field name="prioridad_busqueda" class="java.lang.Integer"/>

    <title>
        <band height="140">
            <rectangle radius="10">
                <reportElement x="20" y="15" width="140" height="55" backcolor="#0A1832"/>
            </rectangle>
            <staticText>
                <reportElement x="30" y="25" width="110" height="18" style="TituloPequeno" forecolor="#FFFFFF"/>
                <text><![CDATA[Premier]]></text>
            </staticText>
            <staticText>
                <reportElement x="30" y="45" width="110" height="15" style="TituloPequeno" forecolor="#FFFFFF"/>
                <text><![CDATA[SERVICES]]></text>
            </staticText>

            <staticText>
                <reportElement x="220" y="30" width="150" height="35" style="TituloGrande" />
                <text><![CDATA[FACTURA]]></text>
            </staticText>

            <staticText>
                <reportElement x="400" y="15" width="80" height="12" style="TextoNegrita"/>
                <text><![CDATA[N° FACTURA:]]></text>
            </staticText>
            <textField>
                <reportElement x="480" y="15" width="100" height="12" style="TextoNormal"/>
                <textFieldExpression><![CDATA["FAC-" + $F{numero_factura}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="400" y="30" width="80" height="12" style="TextoNegrita"/>
                <text><![CDATA[COMPROBANTE:]]></text>
            </staticText>
            <textField>
                <reportElement x="480" y="30" width="100" height="12" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{comprobante}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="400" y="45" width="80" height="12" style="TextoNegrita"/>
                <text><![CDATA[FECHA:]]></text>
            </staticText>
            <textField>
                <reportElement x="480" y="45" width="100" height="12" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{fecha_factura}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="400" y="60" width="80" height="12" style="TextoNegrita"/>
                <text><![CDATA[ESTADO:]]></text>
            </staticText>
            <textField>
                <reportElement x="480" y="60" width="100" height="12" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{estado}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="20" y="85" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="95" width="250" height="12" style="TituloPequeno"/>
                <text><![CDATA[DATOS DE LA EMPRESA]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="112" width="80" height="12" style="TextoNormal"/>
                <text><![CDATA[Dirección:]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="112" width="200" height="12" style="TextoPequeno"/>
                <text><![CDATA[Santiago, República Dominicana]]></text>
            </staticText>

            <staticText>
                <reportElement x="300" y="112" width="60" height="12" style="TextoNormal"/>
                <text><![CDATA[Teléfono:]]></text>
            </staticText>
            <staticText>
                <reportElement x="360" y="112" width="120" height="12" style="TextoPequeno"/>
                <text><![CDATA[849-424-0224]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="126" width="80" height="12" style="TextoNormal"/>
                <text><![CDATA[Email:]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="126" width="200" height="12" style="TextoPequeno"/>
                <text><![CDATA[info@premierservices.do]]></text>
            </staticText>
        </band>
    </title>

    <pageHeader>
        <band height="130">
            <line>
                <reportElement x="20" y="0" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="10" width="250" height="14" style="TituloPequeno"/>
                <text><![CDATA[DATOS DEL CLIENTE]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="28" width="80" height="12" style="TextoNormal"/>
                <text><![CDATA[Empresa:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="28" width="250" height="12" style="TextoNegrita"/>
                <textFieldExpression><![CDATA[$F{nombre_empresa}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="44" width="80" height="12" style="TextoNormal"/>
                <text><![CDATA[Teléfono:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="44" width="150" height="12" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{telefono}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="44" width="60" height="12" style="TextoNormal"/>
                <text><![CDATA[Email:]]></text>
            </staticText>
            <textField>
                <reportElement x="360" y="44" width="200" height="12" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="20" y="60" width="80" height="12" style="TextoNormal"/>
                <text><![CDATA[Dirección:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="60" width="460" height="12" style="TextoPequeno"/>
                <textFieldExpression><![CDATA[$F{ubicacion}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="20" y="85" width="555" height="1"/>
            </line>

            <rectangle radius="5">
                <reportElement x="20" y="95" width="555" height="25" backcolor="#0A1832"/>
            </rectangle>
            <staticText>
                <reportElement x="30" y="100" width="200" height="15" style="HeaderTabla" forecolor="#FFFFFF"/>
                <text><![CDATA[DESCRIPCIÓN DEL SERVICIO]]></text>
            </staticText>
            <staticText>
                <reportElement x="400" y="100" width="60" height="15" style="HeaderTabla" forecolor="#FFFFFF"/>
                <text><![CDATA[CANTIDAD]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="100" width="90" height="15" style="HeaderTabla" forecolor="#FFFFFF"/>
                <text><![CDATA[PRECIO]]></text>
            </staticText>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="0"/>
    </columnHeader>

    <detail>
        <band height="75">
            <line>
                <reportElement x="20" y="0" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement x="30" y="8" width="250" height="12" style="TextoNormal"/>
                <text><![CDATA[Suscripción al Plan]]></text>
            </staticText>
            <textField>
                <reportElement x="30" y="22" width="250" height="15" style="TextoNegrita"/>
                <textFieldExpression><![CDATA[$F{nombre_plan}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="30" y="40" width="80" height="12" style="TextoNormal"/>
                <text><![CDATA[Beneficios:]]></text>
            </staticText>
            <textField isStretchWithOverflow="true">
                <reportElement x="110" y="40" width="350" height="12" style="TextoPequeno"/>
                <textFieldExpression><![CDATA[$F{beneficios}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="400" y="15" width="60" height="15" style="TextoNormal"/>
                <text><![CDATA[1]]></text>
            </staticText>

            <textField pattern="$ #,##0.00">
                <reportElement x="470" y="15" width="90" height="15" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{precio_plan}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <columnFooter>
        <band height="130">
            <line>
                <reportElement x="20" y="0" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement x="380" y="10" width="80" height="15" style="TextoNormal"/>
                <text><![CDATA[SUBTOTAL:]]></text>
            </staticText>
            <textField pattern="$ #,##0.00">
                <reportElement x="460" y="10" width="100" height="15" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{subtotal}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="380" y="28" width="80" height="15" style="TextoNormal"/>
                <text><![CDATA[ITBIS (18%):]]></text>
            </staticText>
            <textField pattern="$ #,##0.00">
                <reportElement x="460" y="28" width="100" height="15" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{subtotal}.multiply(new java.math.BigDecimal("0.18"))]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="380" y="46" width="80" height="15" style="TextoNormal"/>
                <text><![CDATA[DESCUENTO:]]></text>
            </staticText>
            <textField pattern="$ #,##0.00">
                <reportElement x="460" y="46" width="100" height="15" style="TextoNormal"/>
                <textFieldExpression><![CDATA[$F{descuento} != null ? $F{descuento} : new java.math.BigDecimal("0")]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="380" y="65" width="180" height="1"/>
            </line>

            <staticText>
                <reportElement x="380" y="70" width="80" height="18" style="TituloPequeno"/>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>
            <textField pattern="$ #,##0.00">
                <reportElement x="460" y="70" width="100" height="18" style="TituloPequeno"/>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="20" y="100" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="108" width="120" height="12" style="TextoPequeno"/>
                <text><![CDATA[Límite de fotos:]]></text>
            </staticText>
            <textField>
                <reportElement x="140" y="108" width="80" height="12" style="TextoPequeno"/>
                <textFieldExpression><![CDATA[$F{limite_fotos}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="108" width="120" height="12" style="TextoPequeno"/>
                <text><![CDATA[Prioridad búsqueda:]]></text>
            </staticText>
            <textField>
                <reportElement x="420" y="108" width="80" height="12" style="TextoPequeno"/>
                <textFieldExpression><![CDATA[$F{prioridad_busqueda}]]></textFieldExpression>
            </textField>
        </band>
    </columnFooter>

    <pageFooter>
        <band height="40">
            <line>
                <reportElement x="20" y="0" width="555" height="1"/>
            </line>

            <staticText>
                <reportElement x="20" y="10" width="400" height="15" style="TextoPequeno"/>
                <text><![CDATA[Gracias por confiar en Premier Services]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="25" width="400" height="12" style="TextoExtraPequeno"/>
                <text><![CDATA[Este documento es una factura de suscripción.]]></text>
            </staticText>

            <textField>
                <reportElement x="480" y="10" width="100" height="15" style="TextoPequeno"/>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>