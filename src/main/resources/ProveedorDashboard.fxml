<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="668.0" prefWidth="1288.0" style="-fx-background-color: #f0f3f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.premierservices.Controllers.Proveedores.ProveedorDashboardController">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: linear-gradient(to right, #0A1832, #4A7FA9); -fx-padding: 14 24 14 24;">
            <Pane prefHeight="60.0" prefWidth="256.0">
                <children>
                    <Text fill="#50b9ff" layoutX="25.0" layoutY="46.0" stroke="#0d0c0c" strokeType="OUTSIDE" strokeWidth="0.0" text="remier Services">
                        <font><Font name="Elephant Italic" size="31.0" /></font>
                        <effect><Glow level="0.37" /></effect>
                    </Text>
                    <ImageView fx:id="Logoimg" fitHeight="71.0" fitWidth="70.0" layoutX="-12.0" layoutY="-11.0" pickOnBounds="true" preserveRatio="true">
                        <effect><Glow level="0.81" /></effect>
                    </ImageView>
                </children>
            </Pane>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color:#142440; -fx-background-radius:24; -fx-padding:8 16 8 16;">
                <Label style="-fx-font-size:18px;" text="👤" textFill="WHITE" />
                <VBox spacing="1">
                    <Label fx:id="labelNombreProveedor" style="-fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold;" text="Mi Empresa S.A." />
                    <Label style="-fx-text-fill:#4A7FA9; -fx-font-size:10px;" text="Proveedor verificado" />
                </VBox>
            </HBox>
            <Button onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: Black; -fx-border-color: Black; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 6 14 6 14;" text="Cerrar sesión" />
        </HBox>
    </top>

    <!-- CENTRO: TABS -->
    <center>
        <TabPane fx:id="tabPane" style="-fx-background-color:transparent;" tabClosingPolicy="UNAVAILABLE">

            <!-- TAB 1: MI PORTAFOLIO -->
            <Tab text="  📂  Mi Portafolio  ">
                <BorderPane style="-fx-background-color:#f0f3f8;">
                    <top>
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color:white; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2); -fx-padding:16 24 16 24;">
                            <VBox spacing="2">
                                <Label style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0A1832;" text="Mis Servicios" />
                                <Label fx:id="labelTotalServicios" style="-fx-font-size:12px; -fx-text-fill:#6b7280;" text="0 servicios publicados" />
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="210" promptText="🔍  Buscar servicio..." style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#e5e7eb; -fx-padding:7 12 7 12;" />
                            <ComboBox fx:id="comboCategoriaFiltro" onAction="#handleFiltroCategoria" prefWidth="150" promptText="Categoría" style="-fx-background-radius:8;" />
                            <Button fx:id="btnAgregarPortafolio" onAction="#handleAgregarPortafolio" style="-fx-background-color: #4A7FA9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 18 8 18; -fx-font-size: 13px;" text="＋  Agregar Portafolio" />
                        </HBox>
                    </top>
                    <center>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color:transparent; -fx-background:#f0f3f8;">
                            <FlowPane fx:id="flowPaneServicios" hgap="20" style="-fx-background-color:transparent; -fx-padding:24 24 32 24;" vgap="20" />
                        </ScrollPane>
                    </center>
                </BorderPane>
            </Tab>

            <!-- TAB 2: SOLICITUDES -->
            <Tab text="  📋  Solicitudes  ">
                <BorderPane style="-fx-background-color:#f0f3f8;">
                    <top>
                        <VBox style="-fx-background-color:white; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding:16 24 12 24;">
                                <VBox spacing="2">
                                    <Label style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0A1832;" text="Solicitudes Recibidas" />
                                    <Label fx:id="labelTotalSolicitudes" style="-fx-font-size:12px; -fx-text-fill:#6b7280;" text="0 solicitudes" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="comboEstadoFiltro" onAction="#handleFiltroEstado" prefWidth="180" promptText="Filtrar por estado" style="-fx-background-radius:8;" />
                                <Button onAction="#handleRefreshSolicitudes" style="-fx-background-color:#4A7FA9; -fx-text-fill:white; -fx-background-radius:8; -fx-cursor:hand; -fx-padding:7 14 7 14;" text="🔄  Actualizar" />
                            </HBox>
                            <HBox spacing="12" style="-fx-padding:0 24 14 24;">
                                <StackPane style="-fx-background-color:#fff7ed; -fx-background-radius:10; -fx-padding:10 18 10 18;">
                                    <HBox alignment="CENTER" spacing="8">
                                        <Label style="-fx-font-size:16px;" text="⏳" />
                                        <VBox>
                                            <Label fx:id="statPendiente" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#d97706;" text="0" />
                                            <Label style="-fx-font-size:10px; -fx-text-fill:#92400e;" text="Pendientes" />
                                        </VBox>
                                    </HBox>
                                </StackPane>
                                <StackPane style="-fx-background-color:#ecfdf5; -fx-background-radius:10; -fx-padding:10 18 10 18;">
                                    <HBox alignment="CENTER" spacing="8">
                                        <Label style="-fx-font-size:16px;" text="✅" />
                                        <VBox>
                                            <Label fx:id="statConfirmado" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#059669;" text="0" />
                                            <Label style="-fx-font-size:10px; -fx-text-fill:#065f46;" text="Confirmados" />
                                        </VBox>
                                    </HBox>
                                </StackPane>
                                <StackPane style="-fx-background-color:#eff6ff; -fx-background-radius:10; -fx-padding:10 18 10 18;">
                                    <HBox alignment="CENTER" spacing="8">
                                        <Label style="-fx-font-size:16px;" text="🏆" />
                                        <VBox>
                                            <Label fx:id="statCompletado" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#2563eb;" text="0" />
                                            <Label style="-fx-font-size:10px; -fx-text-fill:#1e40af;" text="Completados" />
                                        </VBox>
                                    </HBox>
                                </StackPane>
                                <StackPane style="-fx-background-color:#fef2f2; -fx-background-radius:10; -fx-padding:10 18 10 18;">
                                    <HBox alignment="CENTER" spacing="8">
                                        <Label style="-fx-font-size:16px;" text="❌" />
                                        <VBox>
                                            <Label fx:id="statCancelado" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#dc2626;" text="0" />
                                            <Label style="-fx-font-size:10px; -fx-text-fill:#991b1b;" text="Cancelados" />
                                        </VBox>
                                    </HBox>
                                </StackPane>
                            </HBox>
                        </VBox>
                    </top>
                    <center>
                        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-padding:16 24 24 24;">
                            <TableView fx:id="tablaSolicitudes" style="-fx-background-color:white; -fx-background-radius:12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
                                <columns>
                                    <TableColumn fx:id="colIdReserva" prefWidth="90" text="# Reserva" />
                                    <TableColumn fx:id="colCliente" prefWidth="152.0" text="Cliente" />
                                    <TableColumn fx:id="colServicio" prefWidth="193.0" text="Servicio" />
                                    <TableColumn fx:id="colFechaEvento" prefWidth="167.0" text="Fecha del Evento" />
                                    <TableColumn fx:id="colEstado" prefWidth="137.0" text="Estado" />
                                    <TableColumn fx:id="colAccion" prefWidth="487.0" text="Acción" />
                                </columns>
                                <placeholder>
                                    <VBox alignment="CENTER" spacing="10" style="-fx-padding:40;">
                                        <Label style="-fx-font-size:40px;" text="📭" />
                                        <Label style="-fx-font-size:14px; -fx-text-fill:#6b7280;" text="No hay solicitudes registradas" />
                                    </VBox>
                                </placeholder>
                            </TableView>
                        </ScrollPane>
                    </center>
                </BorderPane>
            </Tab>

        </TabPane>
    </center>

    <!-- STATUS BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color:#0A1832; -fx-padding:5 16 5 16;">
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill:#4A7FA9; -fx-font-size:11px;" text="Premier Services — Panel Proveedor" />
        </HBox>
    </bottom>
</BorderPane>
