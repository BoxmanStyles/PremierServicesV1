                    <padding><Insets bottom="30.0" left="50.0" right="50.0" top="20.0" /></padding>
                    <children>
                        <Pane prefHeight="608.0" prefWidth="1173.0">
                            <children>
                                <!-- Fila 1 -->
                                <Button fx:id="btnGestionClientes" layoutX="39.0" layoutY="40.0" onAction="#onGestionClientesClick" prefHeight="175.0" prefWidth="256.0" style="-fx-background-color: #1469b8; -fx-background-radius: 25px;" text="Gestion Clientes" textFill="WHITE">
                                    <font><Font name="Agency FB" size="32.0" /></font>
                                    <effect><DropShadow /></effect>
                                </Button>

                                <Button fx:id="btnGestionProveedores" layoutX="410.0" layoutY="40.0" onAction="#onGestionProveedoresClick" prefHeight="175.0" prefWidth="256.0" style="-fx-background-color: #1469b8; -fx-background-radius: 25px;" text="Gestion Proveedores" textFill="WHITE">
                                    <font><Font name="Agency FB" size="32.0" /></font>
                                    <effect><DropShadow /></effect>
                                </Button>

                                <Button fx:id="btnGestionPagosFacturas" layoutX="793.0" layoutY="40.0" onAction="#onGestionPagosFacturasClick" prefHeight="175.0" prefWidth="256.0" style="-fx-background-color: #1469b8; -fx-background-radius: 25px;" text="Gestion Facturas" textFill="WHITE">
                                    <font><Font name="Agency FB" size="27.0" /></font>
                                    <effect><DropShadow /></effect>
                                </Button>

                                <!-- Fila 2 -->
                                <Button fx:id="btnGestionReservas" layoutX="39.0" layoutY="323.0" onAction="#onGestionReservasClick" prefHeight="175.0" prefWidth="256.0" style="-fx-background-color: #1469b8; -fx-background-radius: 25px;" text="Gestion Reservas" textFill="WHITE">
                                    <font><Font name="Agency FB" size="32.0" /></font>
                                    <effect><DropShadow><color><Color red="1.0" green="0.040123455226421356" blue="0.040123455226421356" /></color></DropShadow></effect>
                                </Button>

                                <Button fx:id="btnDashboard" layoutX="410.0" layoutY="323.0" onAction="#onDashboardClick" prefHeight="175.0" prefWidth="256.0" style="-fx-background-color: #1469b8; -fx-background-radius: 25px;" text="Dashboard" textFill="WHITE">
                                    <font><Font name="Agency FB" size="32.0" /></font>
                                    <effect><DropShadow /></effect>
                                </Button>
                            </children>
                        </Pane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
