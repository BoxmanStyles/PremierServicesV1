                    <effect><InnerShadow /></effect>
                </Button>
            </children>
         <effect>
            <InnerShadow />
         </effect>
        </Pane>
      <Pane layoutX="21.0" layoutY="212.0" opacity="0.24" prefHeight="666.0" prefWidth="1244.0" style="-fx-border-radius: 25; -fx-background-color: white; -fx-background-radius: 25;">
         <effect>
            <DropShadow spread="0.72" />
