        <HBox alignment="CENTER_LEFT" prefHeight="105.0" prefWidth="1288.0" spacing="20.0" style="-fx-padding: 20; -fx-background-color: linear-gradient(to right, #0A1832, #4A7FA9);">
            <children>
                <Region prefHeight="65.0" prefWidth="448.0" />
                <Pane prefHeight="60.0" prefWidth="256.0">
                    <children>
                        <Text fill="#50b9ff" layoutX="31.0" layoutY="61.0" stroke="#0d0c0c" strokeType="OUTSIDE" strokeWidth="0.0" text="remier Services">
                            <font><Font name="Elephant Italic" size="31.0" /></font>
                            <effect><Glow level="0.37" /></effect>
                        </Text>
                        <ImageView fx:id="Logoimg" fitHeight="71.0" fitWidth="70.0" layoutX="-6.0" layoutY="4.0" pickOnBounds="true" preserveRatio="true">
