                    </children>
                </Pane>
                <Region prefHeight="65.0" prefWidth="87.0" />
                <Pane prefHeight="65.0" prefWidth="138.0" />
                <Pane prefHeight="65.0" prefWidth="138.0" />
            </children>
        </HBox>
      <Rectangle arcHeight="5.0" arcWidth="5.0" height="782.0" layoutY="104.0" stroke="BLACK" strokeType="INSIDE" width="1288.0">
         <fill>
            <RadialGradient centerX="0.5" centerY="0.5" radius="0.5">
               <stops>
                  <Stop>
                     <color>
                        <Color red="0.8470588326454163" green="0.8588235378265381" blue="1.0" />
                     </color>
                  </Stop>
                  <Stop offset="1.0">
                     <color>
                        <Color green="0.2666666805744171" blue="0.5137255191802979" />
                     </color>
                  </Stop>
               </stops>
            </RadialGradient>
         </fill>
      </Rectangle>

        <!-- Contenido del panel -->
        <Pane layoutX="25.0" layoutY="122.0" prefHeight="71.0" prefWidth="1238.0" style="-fx-background-radius: 25; -fx-background-color: white; -fx-border-radius: 25;">
            <children>
                <Text layoutX="528.0" layoutY="47.0" stroke="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Panel Admin" wrappingWidth="182.21478271484375">
                    <font><Font name="System Bold" size="30.0" /></font>
                </Text>
                <!-- Botón de salida (X) que llama a SalirAdminPanel -->
                <Button fx:id="SalirAdminPanel" layoutX="23.0" layoutY="10.0" maxHeight="53.0" maxWidth="57.0" mnemonicParsing="false" onAction="#SalirAdminPanel" prefHeight="53.0" prefWidth="57.0" style="-fx-min-width: 50px; -fx-min-height: 50px; -fx-max-width: 50px; -fx-max-height: 50px; -fx-background-radius: 25px; -fx-background-color: #778899; -fx-text-fill: white; -fx-font-size: 18px;" text="X">
