                                        <Separator />
                                        <Label style="-fx-font-size:13px; -fx-text-fill:#6b7280;"
                                               text="El proveedor ofrece este servicio los siguientes días:" />
                                        <VBox fx:id="vboxDisponibilidad" spacing="10" />
                                    </VBox>
                                </content>
                            </ScrollPane>
                        </Tab>

                    </tabs>
