                <VBox spacing="20" layoutX="20.0" layoutY="20.0" prefWidth="360.0" prefHeight="240.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0A1832;"
                               text="📞 Contactar al proveedor" />

                        <Separator />

                        <!-- Teléfono -->
                        <VBox spacing="8">
                            <Label style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" text="📱 Teléfono" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="contactoTelefono" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
