                                        text="📋 Copiar" />
                            </HBox>
                        </VBox>

                        <!-- Correo -->
                        <VBox spacing="8">
                            <Label style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" text="✉️ Correo electrónico" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="contactoCorreo" style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;"
