                                              style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#e5e7eb; -fx-font-size:13px;" />
                                    <Button fx:id="btnPublicarResena" onAction="#handlePublicarResena"
                                            style="-fx-background-color:#4A7FA9; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8; -fx-cursor:hand; -fx-padding:7 20 7 20; -fx-font-size:13px;"
