                        </VBox>

                        <Separator />

                        <Label style="-fx-font-size: 12px; -fx-text-fill: #9ca3af; -fx-wrap-text: true;"
                               text="💡 Puedes contactar al proveedor directamente por teléfono o correo para consultar disponibilidad y detalles." />
                    </children>
                </VBox>
            </children>
