                                        <Label style="-fx-font-size:12px; -fx-text-fill:#6b7280;" text="Calificación:" />
                                    </HBox>
                                    <TextArea fx:id="txtNuevaResena" prefHeight="56.0" promptText="Escribe tu comentario..."
